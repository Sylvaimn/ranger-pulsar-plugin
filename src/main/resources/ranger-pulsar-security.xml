<configuration>
    <property>
        <name>ranger.plugin.pulsar.service.name</name>
        <value>pulsar</value>
        <description>Name of the Ranger service defining policies for this Pulsar instance</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.policy.source.impl</name>
        <value>org.apache.ranger.admin.client.RangerAdminRESTClient</value>
        <description>Class to retrieve policies from the source</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.policy.rest.url</name>
        <value>http://localhost:6080</value>
        <description>URL to Ranger Admin</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.policy.rest.ssl.config.file</name>
        <value/>
        <description>Path to the truststore file</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.policy.pollIntervalMs</name>
        <value>30000</value>
        <description>Interval to poll for changes in policies</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.policy.cache.dir</name>
        <value>/tmp/ranger-pulsar-policy-cache</value>
        <description>Directory where Ranger policies are cached</description>
    </property>

    <property>
        <name>ranger.plugin.pulsar.enable.cache</name>
        <value>true</value>
    </property>
</configuration>
